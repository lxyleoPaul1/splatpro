        document.head.appendChild(style);
    }

    this.uiWrapper = document.createElement('div');
    this.uiWrapper.className = 'video-float-hud';
    
    // UI HTML：按钮在上方，进度条紧贴屏幕最下方
    this.uiWrapper.innerHTML = `
        <div class="video-row">

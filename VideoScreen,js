    document.body.appendChild(this.uiWrapper);

    this.elPlayBtn = this.uiWrapper.querySelector('#vs-play-btn');
    this.elMuteBtn = this.uiWrapper.querySelector('#vs-mute-btn');
    this.elSlider = this.uiWrapper.querySelector('#vs-slider');
    this.elTime = this.uiWrapper.querySelector('#vs-time');
    this.elFullBtn = this.uiWrapper.querySelector('#vs-full-btn');

    const preventAll = (e) => { e.stopPropagation(); };
    ['mousedown', 'touchstart', 'touchmove', 'touchend', 'click'].forEach(evt => {
        this.uiWrapper.addEventListener(evt, preventAll);
    });

    this.elPlayBtn.addEventListener('click', (e) => { 
        e.preventDefault(); e.stopPropagation(); this._togglePlay(); 
    });
    this.elPlayBtn.addEventListener('touchstart', (e) => { 
        e.preventDefault(); e.stopPropagation(); this._togglePlay(); 
    }, {passive: false});

    this.elMuteBtn.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation(); this._toggleMute();
    });
    this.elMuteBtn.addEventListener('touchstart', (e) => {
        e.preventDefault(); e.stopPropagation(); this._toggleMute();
    }, {passive: false});
    
    this.elFullBtn.addEventListener('click', (e) => { 
        e.preventDefault(); e.stopPropagation(); this._toggleFullscreen(); 
    });
    this.elFullBtn.addEventListener('touchstart', (e) => { 
        e.preventDefault(); e.stopPropagation(); this._toggleFullscreen(); 
    }, {passive: false});
    
    const onSliderInput = (e) => { this._isDraggingSlider = true; e.stopPropagation(); };
    const onSliderChange = (e) => {
        e.stopPropagation();
        if (this._video && this._video.duration) {
            this._video.currentTime = (this.elSlider.value / 100) * this._video.duration;
        }
        this._isDraggingSlider = false;
    };

    this.elSlider.addEventListener('input', onSliderInput);
    this.elSlider.addEventListener('change', onSliderChange);
    this.elSlider.addEventListener('touchstart', (e) => { e.stopPropagation(); });
    this.elSlider.addEventListener('touchmove', (e) => { e.stopPropagation(); });
};

VideoScreen.prototype._setupVideo = function() {
    if (!this.videoUrl) return; 

    // 创建专属的沉浸式全屏容器
    this.fsContainer = document.createElement('div');
    this.fsContainer.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:#000; z-index:99990; display:none; justify-content:center; align-items:center;';
    document.body.appendChild(this.fsContainer);

    var video = document.createElement('video');
    video.crossOrigin = 'anonymous';
    video.loop = true;
    video.muted = true; 
    video.playsInline = true;
    video.preload = 'auto'; 
    video.style.display = 'none';
    
    const onFullscreenExit = () => {
        const isFull = document.fullscreenElement || document.webkitFullscreenElement || (video && video.webkitDisplayingFullscreen);
        if (!isFull) {
            video.controls = false;
            video.style.display = 'none'; 
            
            document.body.appendChild(video);
            if (this.uiWrapper) {
                document.body.appendChild(this.uiWrapper);
                this.uiWrapper.classList.remove('fs-mode');
            }
            if (this.fsContainer) this.fsContainer.style.display = 'none';

            this._updatePlayBtnIcon(!video.paused);
            this._isPlaying = !video.paused;
        }
    };
    document.addEventListener('fullscreenchange', onFullscreenExit);
    document.addEventListener('webkitfullscreenchange', onFullscreenExit);
    video.addEventListener('webkitendfullscreen', onFullscreenExit);

    video.addEventListener('loadedmetadata', () => {
        if (this._texture) return;
        if (video.videoWidth > 0 && video.videoHeight > 0) {
            this._texture = new pc.Texture(this.app.graphicsDevice, {
                format: pc.PIXELFORMAT_R8_G8_B8,
                minFilter: pc.FILTER_LINEAR,
                magFilter: pc.FILTER_LINEAR,
                addressU: pc.ADDRESS_CLAMP_TO_EDGE,
                addressV: pc.ADDRESS_CLAMP_TO_EDGE,
                mipmaps: false,
                width: video.videoWidth,
                height: video.videoHeight
            });
            this.material.emissiveMap = this._texture;
            this.material.update();
        }
    });
    
    video.addEventListener('volumechange', () => {
        this._updateMuteBtnIcon();
    });

    document.body.appendChild(video);
    this._video = video;

    if (Hls.isSupported() && this.videoUrl.indexOf('.m3u8') !== -1) {
        var hls = new Hls();
        hls.loadSource(this.videoUrl);
        hls.attachMedia(video);
        this._hls = hls;
    } else {
        video.src = this.videoUrl;
    }
    this._updateMuteBtnIcon();
};

VideoScreen.prototype.update = function(dt) {
    if (!this.playerEntity || !this.entity.enabled || !this.videoUrl) {
        if(this.uiWrapper) this.uiWrapper.classList.remove('active');
        return;
    }

    this.entity.lookAt(this.playerEntity.getPosition());
    this.entity.rotateLocal(90, 0, 0); 

    if (!this._firstFrameRendered && this._texture && this._video && this._video.readyState >= 2) {
        try {
            if (!this._sourceSet) {
                this._texture.setSource(this._video);
                this._sourceSet = true;
                this.material.emissive = new pc.Color(1, 1, 1); 
                this.material.opacity = 1.0; 
                this.material.update();
            }
            this._texture.upload();
            this._firstFrameRendered = true;
        } catch(e) {}
    }

    var dist = this.entity.getPosition().distance(this.playerEntity.getPosition());

    if (dist <= this.triggerDistance && !window.isSceneTransitioning) {
        
        // 判断屏幕是否在视野正前方，是则显示面板
        this._updateUIPosition(); 

        // 🌟 自动播放：只要靠近，且未被手动暂停，立刻静音自动播放画面！
        if (!this._isPlaying && !this._userPaused) {
            if (this._video && this._video.paused) {
                this._video.muted = true; // 强制静音以允许自动播放
                this._playVideo();
            }
        }
        
        if (this._texture && this._video && !this._video.paused && this._video.readyState >= 2) {
            if (!this._sourceSet) {
                try {
                    this._texture.setSource(this._video);
                    this._sourceSet = true;
                    this.material.emissive = new pc.Color(1, 1, 1);
                    this.material.opacity = 1.0;
                    this.material.update();
                } catch(e) {}
            }
            try { this._texture.upload(); } catch (e) {}
        }

        if (this._video && !this._isDraggingSlider) {
            const percent = (this._video.currentTime / this._video.duration) * 100 || 0;
            this.elSlider.value = percent;
            this._updateTimeDisplay();
        }
    } else {
        if (this.uiWrapper) this.uiWrapper.classList.remove('active');
        if (this._isPlaying) {
            this._pauseVideo();
        }
    }
};

VideoScreen.prototype._updateUIPosition = function() {
    if (!this.uiWrapper || !this.playerEntity.camera) return;
    
    // 如果已经在全屏模式，跳过覆盖
    if (this.uiWrapper.classList.contains('fs-mode')) {
        this.uiWrapper.classList.add('active');
        return;
    }

    const pos = this.entity.getPosition();
    const cameraToPoint = new pc.Vec3().sub2(pos, this.playerEntity.getPosition());
    const forward = this.playerEntity.forward;
    
    // 只要屏幕在视野正前方 (夹角小于 90 度)，就激活显示底部的固定控制面板
    if (forward.dot(cameraToPoint) > 0) {
        this.uiWrapper.classList.add('active');
    } else {
        this.uiWrapper.classList.remove('active');
    }
};

VideoScreen.prototype._togglePlay = function() {
    if (!this._video) return;
    if (this._video.paused) {
        this._playVideo();
        this._userPaused = false; 
    } else {
        this._pauseVideo();
        this._userPaused = true; 
    }
};

VideoScreen.prototype._toggleMute = function() {
    if (!this._video) return;
    this._video.muted = !this._video.muted;
    this._updateMuteBtnIcon();
    
    // 👇 核心机制：用户点击开启声音时，瞬间暂停背景音
    this.app.fire('audio:duck', !this._video.muted);
};

VideoScreen.prototype._toggleFullscreen = function() {
    if (!this._video) return;
    const isFullscreen = document.fullscreenElement || document.webkitFullscreenElement || (this._video && this._video.webkitDisplayingFullscreen);
    
    if (isFullscreen) {
        if (document.exitFullscreen) document.exitFullscreen();
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
        else if (this._video.webkitExitFullscreen) this._video.webkitExitFullscreen();
    } else {
        if (this.isMobile && this._video.webkitEnterFullscreen) {
            this._video.webkitEnterFullscreen(); // iOS
        } else {
            // 电脑端/安卓：自定义沉浸式全屏
            if (this.fsContainer && this.uiWrapper) {
                this.fsContainer.appendChild(this._video);
                this.fsContainer.appendChild(this.uiWrapper);
                
                this._video.style.display = 'block';
                this._video.style.width = '100%';
                this._video.style.height = '100%';
                this._video.style.objectFit = 'contain';
                this._video.controls = false; 
                
                this.uiWrapper.classList.add('fs-mode');
                this.fsContainer.style.display = 'flex';
                
                if (this.fsContainer.requestFullscreen) {
                    this.fsContainer.requestFullscreen();
                } else if (this.fsContainer.webkitRequestFullscreen) {
                    this.fsContainer.webkitRequestFullscreen();
                }
            }
        }
    }
};

VideoScreen.prototype._playVideo = function() {
    if (this._video) {
        var p = this._video.play();
        if (p !== undefined) {
            p.then(() => { 
                this._isPlaying = true;
                this._updatePlayBtnIcon(true);
                // 播放且未静音时，通知主 UI 暂停 BGM
                if (!this._video.muted) {
                    this.app.fire('audio:duck', true);
                }
            }).catch((e) => { 
                 console.warn("Autoplay blocked, muting:", e);
                 this._video.muted = true; 
                 this._video.play(); 
                 this._isPlaying = true; 
                 this._updatePlayBtnIcon(true);
                 this.app.fire('audio:duck', false);
            });
        }
    }
};

VideoScreen.prototype._pauseVideo = function() {
    if (this._video) {
        this._video.pause();
        this._isPlaying = false;
        this._updatePlayBtnIcon(false);
        // 视频暂停时，恢复背景音乐
        this.app.fire('audio:duck', false);
    }
};

VideoScreen.prototype._updatePlayBtnIcon = function(isPlaying) {
    if (!this.elPlayBtn) return;
    if (isPlaying) {
        this.elPlayBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="white"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
    } else {
        this.elPlayBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>`;
    }
};

VideoScreen.prototype._updateMuteBtnIcon = function() {
    if (!this.elMuteBtn || !this._video) return;
    if (this._video.muted) {
        this.elMuteBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="#bf4c41"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>`;
    } else {
        this.elMuteBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="white"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>`;
    }
};

VideoScreen.prototype._updateTimeDisplay = function() {
    if (!this.elTime || !this._video) return;
    const fmt = (s) => {
        if (!s || isNaN(s)) return "00:00";
        const m = Math.floor(s / 60).toString().padStart(2, '0');
        const sec = Math.floor(s % 60).toString().padStart(2, '0');
        return `${m}:${sec}`;
    };
    this.elTime.textContent = `${fmt(this._video.currentTime)} / ${fmt(this._video.duration)}`;
};

VideoScreen.prototype.onDestroy = function() {
    this.off('disable', this._onDisable, this);
    this.app.mouse.off(pc.EVENT_MOUSEDOWN, this._onMouseDown, this);
    if (this.app.touch) this.app.touch.off(pc.EVENT_TOUCHSTART, this._onTouchStart, this);
    
    this.app.off('hls:loaded', this._setupVideo, this);

    if (this._video) {
        this._video.pause();
        this._video.remove();
        this._video = null;
    }
    if (this._hls) this._hls.destroy();
    if (this._texture) {
        this._texture.destroy();
        this._texture = null;
    }
    if (this.uiWrapper) this.uiWrapper.remove();
    if (this.fsContainer) this.fsContainer.remove();
    
    this.app.fire('audio:duck', false);
};
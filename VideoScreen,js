            @media (max-width: 768px) {
                .video-float-hud { padding: 10px 15px 15px 15px; gap: 8px; max-width: 400px; }
                .video-float-hud.active { bottom: 25px; }
                .video-btn { width: 28px; height: 28px; }
                .video-btn svg { width: 20px; height: 20px; }
                .video-time { font-size: 12px; }

                max-width: 600px; 
                padding: 12px 20px 18px 20px; 
                border-radius: 12px;
                background: rgba(15, 15, 15, 0.85); 
                backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
                border: 1px solid rgba(255,255,255,0.15); 
                display: flex; flex-direction: column; gap: 12px;
                z-index: 99999; 

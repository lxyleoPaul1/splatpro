var VideoScreen = pc.createScript('videoScreen');

// --- 属性定义 ---
VideoScreen.attributes.add('videoUrl', { 
    type: 'string', 
    default: '', // 空链接拦截，由外部传入
    title: 'Video URL'
});
VideoScreen.attributes.add('triggerDistance', { type: 'number', default: 15, title: '触发距离' });
VideoScreen.attributes.add('playerTag', { type: 'string', default: 'Player', title: '玩家标签' });

VideoScreen.prototype.initialize = function() {
    // 空场景占位符检测：如果没配置视频，直接自毁隐藏
    if (!this.videoUrl || this.videoUrl.trim() === '') {
        if (this.entity.render) this.entity.render.enabled = false;
        if (this.entity.model) this.entity.model.enabled = false;
        this.entity.enabled = false; 
        return;
    }

    this._video = null;
    this._texture = null;
    this._hls = null;
    this._isPlaying = false;
    this._sourceSet = false;
    this._isDraggingSlider = false;
    this._userPaused = false; 
    this._firstFrameRendered = false;

    this.isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

    this._initUI();

    // HLS流媒体支持
    if (typeof Hls === 'undefined') {
        if (!window.hlsScriptLoading) {
            window.hlsScriptLoading = true;
            var script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/hls.js@latest';
            script.onload = () => {
                window.hlsLoaded = true;
                this.app.fire('hls:loaded');
            };
            document.head.appendChild(script);
        }
        if (!window.hlsLoaded) {
            this.app.on('hls:loaded', this._setupVideo, this);
        } else {
            this._setupVideo();
        }
    } else {
        this._setupVideo();
    }

    // 材质设置
    this.material = new pc.StandardMaterial();
    this.material.emissive = new pc.Color(0, 0, 0); 
    this.material.useLighting = false;
    this.material.cull = pc.CULLFACE_NONE;
    
    // 初始完全透明，防黑屏白块
    this.material.blendType = pc.BLEND_NORMAL;
    this.material.opacity = 0; 
    this.material.depthWrite = false;
    this.material.emissiveMapTiling = new pc.Vec2(-1, 1);
    this.material.emissiveMapOffset = new pc.Vec2(1, 0);
    this.material.update();

    if (this.entity.render) {
        this.entity.render.meshInstances[0].material = this.material;
    } else if (this.entity.model) {
        this.entity.model.material = this.material;
    }
    
    this.playerEntity = this.app.root.findByName('View') || 
                        this.app.root.findByName('Camera') || 
                        this.app.root.findByName('Main Camera');

    this.on('disable', this._onDisable, this);

    if (this.entity.element) {
        this.entity.element.useInput = true;
        this.entity.element.on('click', this._togglePlay, this);
        this.entity.element.on('touchstart', this._togglePlay, this);
    }
    
    this.app.mouse.on(pc.EVENT_MOUSEDOWN, this._onMouseDown, this);
    if (this.app.touch) {
        this.app.touch.on(pc.EVENT_TOUCHSTART, this._onTouchStart, this);
    }
};

VideoScreen.prototype._checkRaycast = function(screenX, screenY) {
    if (!this.playerEntity || !this.playerEntity.camera) return false;
    
    var dist = this.entity.getPosition().distance(this.playerEntity.getPosition());
    if (dist > this.triggerDistance) return false;

    var from = this.playerEntity.camera.screenToWorld(screenX, screenY, this.playerEntity.camera.nearClip);
    var to = this.playerEntity.camera.screenToWorld(screenX, screenY, this.playerEntity.camera.farClip);
    
    var direction = new pc.Vec3().sub2(to, from).normalize();
    var ray = new pc.Ray(from, direction);
    
    var meshInstances = null;
    if (this.entity.render) {
        meshInstances = this.entity.render.meshInstances;
    } else if (this.entity.model) {
        meshInstances = this.entity.model.meshInstances;
    }
    
    if (meshInstances) {
        for (var i = 0; i < meshInstances.length; i++) {
            var aabb = meshInstances[i].aabb;
            if (aabb.intersectsRay(ray)) {
                return true;
            }
        }
    }
    return false;
};

VideoScreen.prototype._onMouseDown = function(e) {
    if (this._checkRaycast(e.x, e.y)) this._togglePlay();
};

VideoScreen.prototype._onTouchStart = function(e) {
    if (e.touches.length === 1 && this._checkRaycast(e.touches[0].x, e.touches[0].y)) {
        this._togglePlay();
    }
};

VideoScreen.prototype._onDisable = function() {
    if (this.uiWrapper) this.uiWrapper.classList.remove('active');
    this.app.fire('audio:duck', false); // 恢复背景音
    if (this._isPlaying) {
        this._pauseVideo();
        this._userPaused = false; 
    }
};

// =========================================================
// UI 重构：强制全局吸底 (Fixed Bottom)，进度条排版在最下方
// =========================================================
VideoScreen.prototype._initUI = function() {
    if (!document.getElementById('video-float-style')) {
        const style = document.createElement('style');
        style.id = 'video-float-style';
        style.innerHTML = `
